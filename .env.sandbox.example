# Common settings for DevContainer and cli_claude environments
# DevContainer 環境と cli_claude 環境の共通な設定
#
# ⚠️  SECURITY NOTE: Values in this file are visible to AI assistants inside the container.
#     Do NOT put secrets, API keys, or tokens here.
#     For secrets, use docker-compose.yml volume mounts (tmpfs / /dev/null) instead.
#
# ⚠️  セキュリティ注意: このファイルの値はコンテナ内の AI から見えます。
#     シークレット・API キー・トークン等は絶対に記載しないでください。
#     秘匿情報は docker-compose.yml のボリュームマウント（tmpfs / /dev/null）で管理してください。

# Run tools like Node.js in development mode (enables verbose logging and other development-friendly behaviors)
# Node.jsなどのツールを開発モードで実行（詳細なログが出るなど、開発に有利な挙動になります）
NODE_ENV=development

# Language / ロケール
# Change to ja_JP.UTF-8 for Japanese output
# 日本語表示にするには ja_JP.UTF-8 に変更してください
LANG=C.UTF-8

# Time Zone
# タイムゾーン
# TZ=Asia/Tokyo

